<!DOCTYPE html>
<html lang="sv">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lästa kurser</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <header>
        <h1>Lästa kurser</h1>
        <nav>
            <a href="/">Hem</a>
            <a href="/add">Lägg till kurs</a>
            <a href="/about">Om</a>
        </nav>
    </header>

    <main>
        <table>
            <tr>
                <th>Kurskod</th>
                <th>Kursnamn</th>
                <th>Kursplan</th>
                <th>Progression</th>
                <th></th>
            </tr>
            <% courses.forEach(course=> { %>
                <tr>
                    <td>
                        <%= course.coursecode %>
                    </td>
                    <td>
                        <%= course.coursename %>
                    </td>
                    <td><a href="<%= course.syllabus %>" target="_blank">Länk</a></td>
                    <td>
                        <%= course.progression %>
                    </td>
                    <td><a href="/delete/<%= course.id %>">X</a></td>
                </tr>
                <% }) %>
        </table>
    </main>
</body>

</html>